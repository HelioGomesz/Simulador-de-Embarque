{
  "name": "simulador-de-embarque",
  "version": "1.0.0",
  "type": "module",
  "description": "Simulador de Embarque para o projeto LumIdeas",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prisma:generate": "prisma generate",
    "prebuild": "npm run prisma:generate",
    "build": "electron-builder",
    "build:win": "npm run prisma:generate && electron-builder --win",
    "build:dir": "npm run prisma:generate && electron-builder --dir",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HelioGomesz/Simulador-de-Embarque.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HelioGomesz/Simulador-de-Embarque/issues"
  },
  "homepage": "https://github.com/HelioGomesz/Simulador-de-Embarque#readme",
  "devDependencies": {
    "electron": "^35.7.4",
    "electron-builder": "^26.0.12",
    "prisma": "^6.12.0"
  },
  "build": {
    "appId": "com.simulador.embarque",
    "productName": "Simulador de Embarque",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!.vscode/**/*",
      "!.github/**/*",
      "!.env.example",
      "!*.md",
      "!README.md",
      "icon.ico"
    ],
    "asarUnpack": [
      "server.js",
      "generated/**/*",
      "prisma/**/*",
      ".env",
      "Imagens/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "Imagens/icon.ico",
      "executableName": "Simulador de Embarque",
      "artifactName": "${productName}-${version}-${ext}.${ext}",
      "forceCodeSigning": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Simulador de Embarque"
    },
    "mac": {
      "icon": "Imagens/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "Imagens/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "axios": "^1.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "xlsx": "^0.18.5"
  }
}
